<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      internalLogLevel="Warn"
      internalLogFile="${basedir}/logs/nlog-internal.log">

  <targets>
    <target xsi:type="Console"
            name="console"
            layout="${longdate} | ${level:uppercase=true:padding=-5} | ${logger:shortName=true} | ${message} ${exception:format=tostring}" />

    <target xsi:type="File"
            name="file"
            fileName="${basedir}/logs/fegusdagent-${shortdate}.log"
            archiveEvery="Day"
            archiveNumbering="Rolling"
            maxArchiveFiles="15"
            layout="${longdate} | ${level:uppercase=true:padding=-5} | ${logger} | ${message} ${exception:format=tostring}" />
  </targets>

  <rules>
    <!-- Suppress noisy Microsoft/System infrastructure logs -->
    <logger name="Microsoft.*" maxlevel="Info" final="true" />
    <logger name="System.Net.Http.*" maxlevel="Info" final="true" />

    <!-- Application and Infrastructure loggers at Debug and above -->
    <logger name="FegusDAgent.*" minlevel="Debug" writeTo="console,file" />

    <!-- Catch-all for anything else -->
    <logger name="*" minlevel="Information" writeTo="console,file" />
  </rules>

</nlog>
