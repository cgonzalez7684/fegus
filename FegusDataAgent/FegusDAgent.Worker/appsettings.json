{ 
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5433;Database=FegusApp;Username=postgres;Password=Car7684$;"    
    
  },
  "AllowedHosts": "*",  
  "EventLog": {
    "LogInformational": true,
    "LogError": true
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName",
      "WithProcessId",
      "WithThreadId"
    ],
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 15,
          "shared": true,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] (ErrorId={ErrorId}) (TraceId={TraceId}) {Message:lj}{NewLine}{Exception}{NewLine}"
        }
      }
    ]
  },
  "IngestionApi": {
    "BaseUrl": "https://appfeguscgr-evakfaanbbc3cwaf.canadacentral-01.azurewebsites.net",
    "CreateSessionPath": "/ingestion/sessions",
    "GetStatusPath": "/ingestion/sessions",
    "CommitPath": "/ingestion/sessions"
  },
  "FegusApi": {
  "BaseUrl": "https://appfeguscgr-evakfaanbbc3cwaf.canadacentral-01.azurewebsites.net",
  "IdCliente": "1001",
  "Username": "user_1",
  "Password": "123456"
  },
  "SaludoWorker": {
    "PollIntervalSeconds": 5,
    "ParallelJobsPerTick": 4,
    "ConsumerCount": 4,
    "ChannelCapacity": 64
  },
  "Checkpoints": {
    "Folder": "Checkpoints"
  }
}